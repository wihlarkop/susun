{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.susun.dev/plan/1.0/schema.json",
  "title": "Susun execution plan",
  "description": "Versioned, deterministic execution plan emitted before runtime mutation.",
  "type": "object",
  "x-susun-artifact": "plan",
  "x-susun-version": {
    "major": 1,
    "minor": 0
  },
  "x-susun-secret-policy": "Plan payloads may reference secret mounts by path and identity, but must not serialize secret contents.",
  "required": ["schema_version", "plan_id", "project", "operation", "actions", "summary"],
  "properties": {
    "schema_version": {
      "$ref": "#/$defs/schema_version"
    },
    "plan_id": {
      "type": "string",
      "pattern": "^plan-[a-f0-9]+$"
    },
    "project": {
      "type": "object",
      "additionalProperties": true
    },
    "operation": {
      "enum": ["up", "down"]
    },
    "created_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "actions": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/action_node"
      }
    },
    "summary": {
      "$ref": "#/$defs/plan_summary"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "schema_version": {
      "type": "object",
      "required": ["major", "minor"],
      "properties": {
        "major": {
          "type": "integer",
          "minimum": 1
        },
        "minor": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "action_node": {
      "type": "object",
      "required": ["id", "action", "dependencies", "reason", "safety"],
      "properties": {
        "id": {
          "type": "string"
        },
        "action": {
          "type": "object",
          "required": ["type", "payload"],
          "properties": {
            "type": {
              "type": "string"
            },
            "payload": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "additionalProperties": false
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "reason": {
          "type": "object",
          "additionalProperties": true
        },
        "safety": {
          "enum": ["safe", "caution", "destructive"]
        }
      },
      "additionalProperties": false
    },
    "plan_summary": {
      "type": "object",
      "required": ["total_actions", "safe_actions", "caution_actions", "destructive_actions"],
      "properties": {
        "total_actions": {
          "type": "integer",
          "minimum": 0
        },
        "safe_actions": {
          "type": "integer",
          "minimum": 0
        },
        "caution_actions": {
          "type": "integer",
          "minimum": 0
        },
        "destructive_actions": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  }
}
