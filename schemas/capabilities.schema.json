{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.susun.dev/capabilities/1.0/schema.json",
  "title": "Susun capability matrix",
  "description": "Published support matrix for a Susun release or development snapshot.",
  "type": "object",
  "x-susun-artifact": "capabilities",
  "x-susun-version": {
    "major": 1,
    "minor": 0
  },
  "x-susun-secret-policy": "Capability matrices are static support metadata and must not contain project values or credentials.",
  "required": ["schema_version", "susun_version", "compose_reference", "features"],
  "properties": {
    "schema_version": {
      "$ref": "#/$defs/schema_version"
    },
    "susun_version": {
      "type": "string"
    },
    "compose_reference": {
      "type": "string"
    },
    "features": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/feature_capability"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "schema_version": {
      "type": "object",
      "required": ["major", "minor"],
      "properties": {
        "major": {
          "type": "integer",
          "minimum": 1
        },
        "minor": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "feature_capability": {
      "type": "object",
      "required": ["support", "scope"],
      "properties": {
        "support": {
          "enum": ["supported", "supported_subset", "experimental", "unsupported"]
        },
        "scope": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
